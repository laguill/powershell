[[blocks]]
type = "prompt"
alignment = "right"

  [[blocks.segments]]
  type = "status"
  style = "diamond"
  foreground = "#414141"
  foreground_templates = [ "{{ if gt .Code 0 }}#D6DEEB{{ end }}" ]
  background = "#03DED3"
  background_templates = [ "{{ if gt .Code 0 }}#E44141{{ end }}" ]
  template = " {{ if gt .Code 0 }}´Çì{{ else }}´Çî{{ end }} "
  leading_diamond = "¯éÂ"

    [blocks.segments.options]
    always_enabled = true

  [[blocks.segments]]
  type = "executiontime"
  style = "diamond"
  foreground = "#D6DEEB"
  background = "#575656"
  template = " ´ëÆ {{ .FormattedMs }} "
  trailing_diamond = "¯é┤"

    [blocks.segments.options]
    style = "roundrock"
    threshold = 0

[[blocks]]
type = "prompt"
alignment = "left"
newline = true

  [[blocks.segments]]
  type = "text"
  style = "plain"
  foreground = "#D6DEEB"
  template = "Ôò¡ÔöÇ"

  [[blocks.segments]]
  type = "time"
  style = "plain"
  foreground = "#F2D3B6"
  template = "{{ .CurrentDate | date .Format }} <#79DFE1>|</>"

    [blocks.segments.options]
    time_format = "<#D6DEEB>¯Öü 15:04:05</> <#79DFE1>|</> ´ü│ 2 Jan, Monday"

  [[blocks.segments]]
  type = "path"
  style = "diamond"
  foreground = "#B6D6F2"
  template = " {{ .Path }} "
  leading_diamond = "<#00C7FC> ´ü╗ </><#B6D6F2> in </>"

    [blocks.segments.options]
    folder_icon = " ´ü╝ "
    folder_separator_icon = " ´üí "
    home_icon = "¯¼å "
    style = "agnoster_short"
    max_depth = 3

[[blocks]]
type = "prompt"
alignment = "left"
newline = true

  [[blocks.segments]]
  type = "text"
  style = "plain"
  foreground = "#D6DEEB"
  template = "Ôò░ÔöÇ"

    [blocks.segments.cache]
