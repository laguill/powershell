  style = "diamond"
  foreground = "#D6DEEB"
  background = "#575656"
  template = " {{ if .WSL }}¯£Æ on {{ end }}{{ .Icon }} "
  powerline_symbol = "¯é┤"
  leading_diamond = "¯éÂ"
  leading_powerline_symbol = "¯âö"

    [blocks.segments.options]
    alpine = "´îÇ"
    arch = "´îâ"
    centos = "´îä"
    debian = "´îå"
    elementary = "´îë"
    fedora = "´îè"
    gentoo = "´îì"
    linux = "¯£Æ"
    macos = "¯£æ"
    manjaro = "´îÆ"
    mint = "´îÅ"
    opensuse = "´îö"
    raspbian = "´îò"
    ubuntu = "´î£"
    windows = "¯£Å"

    [blocks.segments.cache]
    duration = "5m"
