"$schema" = "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json"
version = 4
console_title_template = "{{ if .Root }}root @ {{ end }}{{ .Shell }} in {{ .Folder }}"
patch_pwsh_bleed = true

[[blocks]]
type = "prompt"
alignment = "left"

  [[blocks.segments]]
  type = "os"
  style = "diamond"
  foreground = "#D6DEEB"
  background = "#575656"
  template = " {{ if .WSL }} on {{ end }}{{ .Icon }} "
  powerline_symbol = ""
  leading_diamond = ""
  leading_powerline_symbol = ""

    [blocks.segments.options]
    alpine = ""
    arch = ""
    centos = ""
    debian = ""
    elementary = ""
    fedora = ""
    gentoo = ""
    linux = ""
    macos = ""
    manjaro = ""
    mint = ""
    opensuse = ""
    raspbian = ""
    ubuntu = ""
    windows = ""

    [blocks.segments.cache]
    duration = "5m"
    strategy = "session"

  [[blocks.segments]]
  type = "session"
  style = "powerline"
  foreground = "#ffffff"
  background = "#ff2eee"
  template = "  {{ .UserName }}@{{ .HostName }} "
  powerline_symbol = ""

    [blocks.segments.options]
    ssh_icon = "📡"
    display_host = true

  [[blocks.segments]]
  type = "shell"
  style = "accordion"
  foreground = "#011627"
  background = "#00C7FC"
  template = "  {{ .Name }} "
  powerline_symbol = ""

  [[blocks.segments]]
  type = "root"
  style = "powerline"
  foreground = "#D6DEEB"
  background = "#EF541C"
  template = "  admin "
  powerline_symbol = ""

  [[blocks.segments]]
  type = "cmake"
  style = "powerline"
  foreground = "#E8EAEE"
  background = "#1E9748"
  template = "   cmake {{ .Full }} "
  powerline_symbol = ""

  [[blocks.segments]]
  type = "python"
  style = "powerline"
  foreground = "#011627"
  background = "#FFDE57"
  template = "  {{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }} "
  powerline_symbol = ""

    [blocks.segments.options]
    display_mode = "context"

  [[blocks.segments]]
  type = "go"
  style = "powerline"
  foreground = "#ffffff"
  background = "#7FD5EA"
  template = " ‭ {{ .Full }} "
  powerline_symbol = ""

  [[blocks.segments]]
  type = "rust"
  style = "powerline"
  foreground = "#193549"
  background = "#99908A"
  template = "  {{ .Full }} "
  powerline_symbol = ""

  [[blocks.segments]]
  type = "git"
  style = "powerline"
  foreground = "#011627"
  background = "#1BD4CD"
  background_templates = [
  "{{ if or (.Working.Changed) (.Staging.Changed) }}#16B1AC{{ end }}",
  "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#16B1AC{{ end }}",
  "{{ if gt .Ahead 0 }}#B787D7{{ end }}",
  "{{ if gt .Behind 0 }}#B787D7{{ end }}"
]
  template = " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}<#CAEBE1>  {{ .Staging.String }}</>{{ end }}{{ if gt .StashCount 0 }}  {{ .StashCount }}{{ end }} "
  powerline_symbol = ""

    [blocks.segments.options]
    branch_icon = " "
    fetch_status = true
    fetch_upstream_icon = true

  [[blocks.segments]]
  type = "docker"
  style = "powerline"
  foreground = "#011627"
  background = "#33a3db"
  template = "  {{ .Context }} "
  powerline_symbol = ""

    [blocks.segments.cache]
    duration = "30s"
    strategy = "session"

  [[blocks.segments]]
  type = "aws"
  style = "powerline"
  foreground = "#011627"
  background = "#ffb042"
  template = "  {{ .Profile }}{{ if .Region }}@{{ .Region }}{{ end }} "
  powerline_symbol = ""

    [blocks.segments.cache]
    duration = "1h"
    strategy = "session"

[[blocks]]
type = "prompt"
alignment = "right"

  [[blocks.segments]]
  type = "claude"
  style = "diamond"
  foreground = "#011627"
  background = "#81C8BE"
  leading_diamond = "\ue0b6"
  trailing_diamond = "\ue0b4"
  template = " {{ if contains \"opus\" .Model.ID }}\uf219{{ else if contains \"haiku\" .Model.ID }}\uf0e7{{ else }}\U000F04A9{{ end }} {{ .Model.DisplayName }} \ue0b3 {{ .TokenUsagePercent.Gauge }} {{ .TokenUsagePercent.String }}% "
  background_templates = [
    "{{ if gt .TokenUsagePercent 80.0 }}#E78284{{ end }}",
    "{{ if gt .TokenUsagePercent 50.0 }}#E5C890{{ end }}"
  ]

  [[blocks.segments]]
  type = "claude"
  style = "diamond"
  foreground = "#C6D0F5"
  background = "#626880"
  leading_diamond = "\ue0b6"
  trailing_diamond = "\ue0b4"
  template = "{{ if gt .Cost.TotalCostUSD 0.0 }} \uf0d6 {{ .FormattedCost }} {{ end }}"
  foreground_templates = [ "{{ if gt .Cost.TotalCostUSD 0.5 }}#011627{{ end }}" ]
  background_templates = [
    "{{ if gt .Cost.TotalCostUSD 1.0 }}#E78284{{ end }}",
    "{{ if gt .Cost.TotalCostUSD 0.5 }}#EF9F76{{ end }}"
  ]

  [[blocks.segments]]
  type = "status"
  style = "diamond"
  foreground = "#414141"
  foreground_templates = [ "{{ if gt .Code 0 }}#D6DEEB{{ end }}" ]
  background = "#03DED3"
  background_templates = [ "{{ if gt .Code 0 }}#E44141{{ end }}" ]
  template = " {{ if gt .Code 0 }}{{ else }}{{ end }} "
  leading_diamond = ""

    [blocks.segments.options]
    always_enabled = true

  [[blocks.segments]]
  type = "executiontime"
  style = "diamond"
  foreground = "#D6DEEB"
  background = "#575656"
  template = "  {{ .FormattedMs }} "
  trailing_diamond = ""

    [blocks.segments.options]
    style = "roundrock"
    threshold = 0

[[blocks]]
type = "prompt"
alignment = "left"
newline = true

  [[blocks.segments]]
  type = "text"
  style = "plain"
  foreground = "#D6DEEB"
  template = "╭─"

  [[blocks.segments]]
  type = "time"
  style = "plain"
  foreground = "#F2D3B6"
  template = "{{ .CurrentDate | date .Format }} <#79DFE1>|</>"

    [blocks.segments.options]
    time_format = "<#D6DEEB> 15:04:05</> <#79DFE1>|</>  2 Jan, Monday"

  [[blocks.segments]]
  type = "path"
  style = "diamond"
  foreground = "#B6D6F2"
  template = " {{ .Path }} "
  leading_diamond = "<#00C7FC>  </><#B6D6F2> in </>"

    [blocks.segments.options]
    folder_icon = "  "
    folder_separator_icon = "  "
    home_icon = " "
    style = "agnoster_short"
    max_depth = 3

[[blocks]]
type = "prompt"
alignment = "left"
newline = true

  [[blocks.segments]]
  type = "text"
  style = "plain"
  foreground = "#D6DEEB"
  template = "╰─"

    [blocks.segments.cache]
    duration = "5m"
    strategy = "session"

  [[blocks.segments]]
  type = "status"
  style = "plain"
  foreground = "#D6DEEB"
  template = "❯ "

    [blocks.segments.options]
    always_enabled = true

[transient_prompt]
background = "transparent"
foreground = "#FEF5ED"
template = " "

[secondary_prompt]
background = "transparent"
foreground = "#D6DEEB"
template = "╰─❯ "
