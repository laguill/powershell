  [[blocks.segments]]
  type = "rust"
  style = "powerline"
  foreground = "#193549"
  background = "#99908A"
  template = " ¯×¿ {{ .Full }} "
  powerline_symbol = "¯é░"

  [[blocks.segments]]
  type = "git"
  style = "powerline"
  foreground = "#011627"
  background = "#1BD4CD"
  background_templates = [
  "{{ if or (.Working.Changed) (.Staging.Changed) }}#16B1AC{{ end }}",
  "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#16B1AC{{ end }}",
  "{{ if gt .Ahead 0 }}#B787D7{{ end }}",
  "{{ if gt .Behind 0 }}#B787D7{{ end }}"
]
  template = " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} ´üä {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}<#CAEBE1> ´üå {{ .Staging.String }}</>{{ end }}{{ if gt .StashCount 0 }} ¯¡ï {{ .StashCount }}{{ end }} "
  powerline_symbol = "¯é░"

    [blocks.segments.options]
    branch_icon = "¯£Ñ "
    fetch_status = true
    fetch_upstream_icon = true

  [[blocks.segments]]
  type = "docker"
  style = "powerline"
  foreground = "#011627"
  background = "#33a3db"
  template = " ´îê {{ .Context }} "
  powerline_symbol = "¯é░"

    [blocks.segments.cache]
    duration = "30s"
    strategy = "session"

  [[blocks.segments]]
  type = "aws"
  style = "powerline"
  foreground = "#011627"
  background = "#ffb042"
  template = " ¯×¡ {{ .Profile }}{{ if .Region }}@{{ .Region }}{{ end }} "
