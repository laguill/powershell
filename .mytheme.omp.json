  powerline_symbol = "¯é░"

  [[blocks.segments]]
  type = "cmake"
  style = "powerline"
  foreground = "#E8EAEE"
  background = "#1E9748"
  template = " ¯ÿ× ¯ÿØ cmake {{ .Full }} "
  powerline_symbol = "¯é░"

  [[blocks.segments]]
  type = "python"
  style = "powerline"
  foreground = "#011627"
  background = "#FFDE57"
  template = " ¯£╝ {{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }} "
